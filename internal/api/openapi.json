{
  "openapi": "3.1.0",
  "info": {
    "title": "Gamarr API",
    "description": "Self-hosted game and ROM search, download, and library manager. The HTTP/JSON API powers both the SPA and any external tooling (CLI scripts, AI agents, *arr-family integrations).",
    "version": "1.x",
    "license": {"name": "MIT", "identifier": "MIT"}
  },
  "servers": [
    {"url": "http://localhost:5001", "description": "Default local install"}
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "API key for programmatic access. Also accepted via ?apikey= query parameter."
      },
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "gamarr_session",
        "description": "Set by POST /api/login. Used by the SPA."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["success", "error"],
        "properties": {
          "success": {"type": "boolean", "enum": [false]},
          "error":   {"type": "string"}
        }
      },
      "SearchResult": {
        "type": "object",
        "description": "A single game/ROM search hit. Fields are populated per source — DDL sources omit seeders/leechers; torrent sources usually omit detail-page GUIDs.",
        "properties": {
          "title":          {"type": "string"},
          "size":           {"type": "integer", "format": "int64", "description": "Bytes."},
          "size_human":     {"type": "string"},
          "seeders":        {"type": "integer"},
          "leechers":       {"type": "integer"},
          "indexer":        {"type": "string"},
          "download_url":   {"type": "string", "format": "uri"},
          "magnet_url":     {"type": "string"},
          "info_hash":      {"type": "string"},
          "guid":           {"type": "string"},
          "platform":       {"type": "string"},
          "platform_slug":  {"type": "string"},
          "source_type":    {"type": "string", "enum": ["torrent", "ddl"]},
          "safety_score":   {"type": "integer", "description": "0-100; higher is safer."},
          "score":          {"type": "integer"},
          "in_library":     {"type": "boolean"}
        }
      },
      "WishlistItem": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "id":            {"type": "integer", "format": "int64"},
          "title":         {"type": "string", "maxLength": 500},
          "platform":      {"type": "string", "maxLength": 100},
          "platform_slug": {"type": "string", "maxLength": 50}
        }
      },
      "BulkJobRequest": {
        "type": "object",
        "description": "Empty or missing job_ids means 'operate on all matching jobs' (failed for retry, active for cancel).",
        "properties": {
          "job_ids": {"type": "array", "items": {"type": "string"}, "maxItems": 500}
        }
      },
      "BulkResult": {
        "type": "object",
        "properties": {
          "success":   {"type": "boolean"},
          "requested": {"type": "integer"},
          "succeeded": {"type": "integer"},
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "job_id":  {"type": "string"},
                "id":      {"type": "integer"},
                "success": {"type": "boolean"},
                "message": {"type": "string"}
              }
            }
          }
        }
      }
    }
  },
  "security": [{"apiKey": []}, {"session": []}],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health check",
        "description": "Liveness probe. Returns 200 if the binary is running. No auth required.",
        "security": [],
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/openapi.json": {
      "get": {
        "summary": "This OpenAPI spec",
        "description": "Returns this OpenAPI 3.1 document. AI agents can fetch this to discover endpoints.",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI 3.1 document",
            "content": {"application/json": {"schema": {"type": "object"}}}
          }
        }
      }
    },
    "/api/auth/status": {
      "get": {
        "summary": "Current auth state",
        "responses": {"200": {"description": "auth status"}}
      }
    },
    "/api/platforms": {
      "get": {
        "summary": "List supported gaming platforms",
        "description": "Returns the platform slugs Gamarr's drivers recognize (e.g., nes, snes, ps2, pc).",
        "responses": {"200": {"description": "platform list"}}
      }
    },
    "/api/search": {
      "get": {
        "summary": "Search all configured sources for a game/ROM",
        "parameters": [
          {"name": "q",        "in": "query", "required": true, "schema": {"type": "string"}, "description": "Search query."},
          {"name": "platform", "in": "query", "required": false, "schema": {"type": "string"}, "description": "Platform slug filter, e.g. 'nes'. Omit or 'all' for cross-platform."}
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results":        {"type": "array", "items": {"$ref": "#/components/schemas/SearchResult"}},
                    "search_time_ms": {"type": "integer"},
                    "sources":        {"type": "array", "items": {"type": "object"}}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sources": {
      "get": {
        "summary": "List configured search sources + health",
        "description": "Returns each registered source with enabled state, circuit-breaker status, last success/fail counters."
      }
    },
    "/api/sources/health": {
      "get": {"summary": "Detailed source health"}
    },
    "/api/sources/{name}/reset": {
      "post": {
        "summary": "Reset a source's circuit breaker",
        "parameters": [{"name": "name", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Reset"}}
      }
    },
    "/api/downloads": {
      "get": {"summary": "List active and recent downloads"}
    },
    "/api/downloads/{jobID}/retry": {
      "post": {
        "summary": "Retry a single failed download",
        "parameters": [{"name": "jobID", "in": "path", "required": true, "schema": {"type": "string"}}]
      }
    },
    "/api/admin/bulk/retry": {
      "post": {
        "summary": "Retry many failed jobs at once",
        "description": "Empty body retries ALL failed jobs. Otherwise retries the specified job_ids.",
        "requestBody": {
          "required": false,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkJobRequest"}}}
        },
        "responses": {
          "200": {"description": "Per-id outcomes", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkResult"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Error"}}}}
        }
      }
    },
    "/api/admin/bulk/cancel": {
      "post": {
        "summary": "Cancel many active jobs at once",
        "description": "Empty body cancels ALL active jobs. Otherwise cancels the specified job_ids.",
        "requestBody": {
          "required": false,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkJobRequest"}}}
        },
        "responses": {
          "200": {"description": "Per-id outcomes", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkResult"}}}}
        }
      }
    },
    "/api/library": {
      "get": {
        "summary": "List items in the library",
        "parameters": [
          {"name": "page",     "in": "query", "schema": {"type": "integer", "minimum": 1, "default": 1}},
          {"name": "page_size","in": "query", "schema": {"type": "integer", "minimum": 1, "maximum": 500, "default": 50}},
          {"name": "platform", "in": "query", "schema": {"type": "string"}}
        ]
      }
    },
    "/api/wishlist": {
      "get":  {"summary": "List wishlist items"},
      "post": {
        "summary": "Add a wishlist item",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/WishlistItem"}}}
        },
        "responses": {
          "200": {"description": "Created"},
          "400": {"description": "Validation error",     "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Error"}}}},
          "415": {"description": "Wrong Content-Type",   "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Error"}}}}
        }
      }
    },
    "/api/wishlist/{id}": {
      "delete": {
        "summary": "Delete a wishlist item",
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "integer", "format": "int64", "minimum": 1}}],
        "responses": {
          "200": {"description": "Deleted"},
          "400": {"description": "Invalid id"}
        }
      }
    },
    "/api/wishlist/bulk-delete": {
      "post": {
        "summary": "Delete many wishlist items at once",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ids"],
                "properties": {"ids": {"type": "array", "items": {"type": "integer"}, "maxItems": 500, "minItems": 1}}
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Per-id outcomes", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BulkResult"}}}}
        }
      }
    },
    "/api/test/prowlarr":     {"post": {"summary": "Connectivity test: Prowlarr"}},
    "/api/test/qbittorrent":  {"post": {"summary": "Connectivity test: qBittorrent"}},
    "/api/test/sabnzbd":      {"post": {"summary": "Connectivity test: SABnzbd"}},
    "/api/test/transmission": {"post": {"summary": "Connectivity test: Transmission"}},
    "/api/test/deluge":       {"post": {"summary": "Connectivity test: Deluge"}},
    "/torznab/api": {
      "get": {
        "summary": "Torznab indexer API",
        "description": "Lets Prowlarr / Sonarr / other *arr apps use Gamarr as a Torznab indexer. ?t=caps returns the capabilities document; ?t=search&q=<title> returns RSS results.",
        "parameters": [
          {"name": "t",      "in": "query", "schema": {"type": "string", "enum": ["caps", "search", "console-search", "pc-search"]}},
          {"name": "q",      "in": "query", "schema": {"type": "string"}, "description": "Search query (omit for caps)."},
          {"name": "platform","in": "query", "schema": {"type": "string"}, "description": "Gamarr platform slug filter."},
          {"name": "apikey", "in": "query", "schema": {"type": "string"}, "description": "Required when TORZNAB_API_KEY is set."}
        ],
        "responses": {
          "200": {"description": "Torznab XML (RSS feed or caps document)", "content": {"application/xml": {}}}
        }
      }
    },
    "/metrics": {
      "get": {"summary": "Prometheus metrics", "security": []}
    }
  }
}
