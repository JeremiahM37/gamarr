# Gamarr — Environment Variables
# Copy to .env and fill in your values

# ── Prowlarr ──────────────────────────────────────────────────────────────────
PROWLARR_URL=http://prowlarr:9696           # Docker service name or IP
PROWLARR_API_KEY=your_prowlarr_api_key_here

# ── qBittorrent ───────────────────────────────────────────────────────────────
# If running behind a VPN container (gluetun), qBit is at localhost inside the
# shared network namespace. Otherwise use the container name.
QB_URL=http://localhost:8080
QB_USER=admin
QB_PASS=your_qbittorrent_password

# ── Storage Paths (inside the container) ─────────────────────────────────────
# Where qBit saves game downloads
QB_SAVE_PATH=/games-incoming/

# Destination for PC game repacks (e.g. FitGirl/DODI)
GAMES_VAULT_PATH=/vault

# Destination for ROM files, organised by platform slug (e.g. /roms/switch/)
GAMES_ROMS_PATH=/roms
