# =============================================================================
# Gamarr — Environment Configuration
# Copy to .env and fill in your values.
# =============================================================================

# --- Prowlarr (required for torrent search) ---
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# --- qBittorrent (required for torrent downloads) ---
QB_URL=http://qbittorrent:8080
QB_USER=admin
QB_PASS=your_qbittorrent_password
QB_SAVE_PATH=/data/incoming/
QB_CATEGORY=games

# --- Storage paths (inside the container) ---
# Mount these volumes in docker-compose.yml
GAMES_VAULT_PATH=/data/vault       # PC games go here
GAMES_ROMS_PATH=/data/roms         # Console ROMs go here, organized by platform slug

# --- Gamarr data directory ---
# Stores the SQLite job database and custom source config
DATA_DIR=/data/gamarr

# --- ClamAV (optional - antivirus scanning) ---
# Set CLAMAV_CONTAINER to your ClamAV container name if you have one.
# Leave blank to skip virus scanning (not recommended for untrusted sources).
# CLAMAV_CONTAINER=clamav
# CLAMAV_SOCKET=/run/clamav/clamd.sock

# --- Prowlarr indexer selection (optional) ---
# Comma-separated list of Prowlarr indexer IDs to query for games.
# Default: 1337x(7), TPB(5), KAT(15), BitSearch(9), Knaben(8), Nyaa(3), LimeTorrents(4)
# PROWLARR_GAME_INDEXERS=7,5,15,9,8,3,4

# --- Source-specific config (optional) ---
# Custom sources can use SOURCE_{NAME}_{KEY} env vars.
# Example: SOURCE_MYPRIVATETRACKER_API_KEY=xxxx

# ── AI Monitor (optional — monitors workflow and auto-heals issues) ─────────────
# AI_MONITOR_ENABLED=true
# AI_PROVIDER=ollama                    # ollama | openai | anthropic
# AI_API_URL=http://ollama:11434/v1     # base URL for ollama or openai-compatible
# AI_API_KEY=                           # required for openai / anthropic
# AI_MODEL=llama3.2                     # model name (e.g. llama3.2, gpt-4o, claude-opus-4-6)
# AI_MONITOR_INTERVAL=300               # seconds between auto-analysis cycles
# AI_AUTO_FIX=true                      # auto-apply safe fixes (set false for approval-only)
